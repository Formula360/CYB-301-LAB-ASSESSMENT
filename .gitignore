# =============================================================
#  CRYPTO LAB — .gitignore
# =============================================================

# ── Environment & Secrets (NEVER commit these) ──
.env
.env.local
.env.production
.env.development
*.env

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
dist/
build/
*.egg

# ── Node / JS (if ever used) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── OS Files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor & IDE ──
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Logs ──
logs/
*.log

# ── Temp / Build ──
tmp/
temp/
.cache/
